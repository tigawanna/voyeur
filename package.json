{
  "name": "reelroom",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3072",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate:local": "wrangler d1 migrations apply reelroom-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply reelroom-db --remote",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check ."
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@cloudflare/vite-plugin": "^1.42.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.1.18",
    "@tanem/react-nprogress": "^6.0.3",
    "@tanstack/db": "^0.6.9",
    "@tanstack/db-collections": "^0.0.24",
    "@tanstack/query-db-collection": "^1.0.41",
    "@tanstack/react-db": "^0.1.87",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "daisyui": "^5.5.23",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "hono": "^4.12.26",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.545.0",
    "next-themes": "^0.4.6",
    "nitro": "npm:nitro-nightly@latest",
    "radix-ui": "^1.6.0",
    "react": "^19.2.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260619.1",
    "@kubb/cli": "^4.38.1",
    "@kubb/core": "^4.38.1",
    "@kubb/plugin-oas": "^4.38.1",
    "@kubb/plugin-ts": "^4.38.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.20.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.102.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
